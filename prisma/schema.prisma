// Prisma schema — https://pris.ly/d/prisma-schema
// Prisma 7: the connection URL lives in prisma.config.ts (for the CLI/Migrate),
// and the runtime PrismaClient connects through a driver adapter (see src/lib/db.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Application user, linked 1:1 to a Clerk user via `clerkId`.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}